# Enter your code here. Read input from STDIN. Print output to STDOUT
from collections import defaultdict

# Read n and m
n, m = map(int, input().split())
d = defaultdict(list)

# Read Group A and store 1-based indices
for i in range(1, n + 1):
    d[input()].append(str(i))

# Read Group B and output results
for _ in range(m):
    word_b = input()
    if word_b in d:
        print(" ".join(d[word_b]))
    else:
        print("-1")
