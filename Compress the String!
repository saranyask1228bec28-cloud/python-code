# Enter your code here. Read input from STDIN. Print output to STDOUT
from itertools import groupby

def compress_string():
    # Read the input string
    s = input().strip()
    
    # Use groupby to find consecutive identical characters
    # k is the character, g is the group (iterable)
    result = []
    for k, g in groupby(s):
        count = len(list(g))
        result.append(f"({count}, {k})")
    
    # Join the results with a space
    print(" ".join(result))

if __name__ == "__main__":
    compress_string()
