# Enter your code here. Read input from STDIN. Print output to STDOUT
# Step 1: Read input for Set M
m_size = int(input())
m_elements = set(map(int, input().split()))

# Step 2: Read input for Set N
n_size = int(input())
n_elements = set(map(int, input().split()))

# Step 3: Find the symmetric difference
# This finds elements in M or N, but not both
sym_diff = m_elements.symmetric_difference(n_elements)

# Step 4: Sort the results and print
for value in sorted(sym_diff):
    print(value)

