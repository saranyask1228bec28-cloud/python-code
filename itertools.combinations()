# Enter your code here. Read input from STDIN. Print output to STDOUT
from itertools import combinations

# Read the input and split into string S and integer k
S, k = input().split()
k = int(k)

# Sort the string alphabetically to ensure lexicographic order
S = sorted(S)

# Loop through each size from 1 to k
for i in range(1, k + 1):
    # Generate combinations of size 'i'
    for combo in combinations(S, i):
        # Join the tuple into a string and print
        print("".join(combo))
