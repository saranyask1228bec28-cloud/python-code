# Enter your code here. Read input from STDIN. Print output to STDOUT
from collections import Counter

# 1. Read the number of shoes (though not strictly needed for the logic)
num_shoes = int(input())

# 2. Read shoe sizes and convert them into a frequency dictionary
shoe_inventory = Counter(map(int, input().split()))

# 3. Read the number of customers
num_customers = int(input())

total_revenue = 0

# 4. Process each customer
for _ in range(num_customers):
    size, price = map(int, input().split())
    
    # Check if the shoe size is in stock
    if shoe_inventory[size] > 0:
        total_revenue += price
        shoe_inventory[size] -= 1  # Reduce stock by 1

# 5. Output the result
print(total_revenue)
