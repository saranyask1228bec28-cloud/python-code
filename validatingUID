import sys

def validate_uid(uid):
    # Rule 5: There must be exactly 10 characters
    if len(uid) != 10:
        return False
    
    # Rule 3: It should only contain alphanumeric characters
    if not uid.isalnum():
        return False
    
    # Rule 4: No character should repeat
    if len(set(uid)) != 10:
        return False
    
    # Rule 1: At least 2 uppercase English alphabet characters
    upper_count = sum(1 for char in uid if char.isupper())
    if upper_count < 2:
        return False
    
    # Rule 2: At least 3 digits (0-9)
    digit_count = sum(1 for char in uid if char.isdigit())
    if digit_count < 3:
        return False
    
    return True

# Input handling
input_data = sys.stdin.read().split()
if input_data:
    t = int(input_data[0])
    uids = input_data[1:]
    
    for i in range(t):
        if validate_uid(uids[i]):
            print("Valid")
        else:
            print("Invalid")

